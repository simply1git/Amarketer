---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts', (p) => p.data.status === 'published'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base
  title="AI Tools for Teachers & Students, Actually Tested"
  description="Hands-on reviews and comparisons of AI teaching and study tools — lesson planners, quiz generators, writing feedback and more. Every tool tested for real."
>
  <h1>AI tools for the classroom — actually tested, honestly reviewed</h1>
  <p>
    Every review here comes from hands-on testing on real teaching and study
    tasks — not vendor marketing pages. We show you what each tool does well,
    where it falls apart, and which one fits your situation.
  </p>
  {posts.length === 0 ? (
    <p><em>First reviews are in testing right now — subscribe below to get them first.</em></p>
  ) : (
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.id}`}>{post.data.title}</a>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Base>
