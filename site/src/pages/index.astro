---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts', (p) => p.data.status === 'published'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base
  title="AI Tools for One-Person Businesses, Actually Tested"
  description="Hands-on reviews of AI and automation tools for freelancers, creators, and solo founders — funnel builders, email tools, writing assistants. Tested for real."
>
  <h1>The tool stack for your one-person business — actually tested</h1>
  <p>
    Every tool featured here was signed up for, used on real tasks, and pushed
    until it broke or proved itself. We tell you what each one actually does,
    what the free plan really includes, and which one fits your situation — no
    hype, no income promises, just working tools.
  </p>
  {posts.length === 0 ? (
    <p><em>First reviews are in testing right now — subscribe below to get them first.</em></p>
  ) : (
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.id}`}>{post.data.title}</a>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</Base>
