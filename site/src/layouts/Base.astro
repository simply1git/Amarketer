---
interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const siteName = 'Classroom Stack';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <style>
      :root { --ink: #1a1a2e; --muted: #5c5c70; --accent: #2563eb; --bg: #ffffff; --soft: #f4f6fb; }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; color: var(--ink); background: var(--bg); line-height: 1.65; }
      header, main, footer { max-width: 46rem; margin: 0 auto; padding: 0 1.25rem; }
      header { display: flex; align-items: baseline; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 1rem; }
      header a.brand { font-weight: 700; font-size: 1.15rem; color: var(--ink); text-decoration: none; }
      header nav a { color: var(--muted); text-decoration: none; margin-left: 1rem; }
      main { padding-bottom: 3rem; }
      h1 { line-height: 1.25; }
      a { color: var(--accent); }
      article :global(table) { border-collapse: collapse; width: 100%; display: block; overflow-x: auto; }
      article :global(th), article :global(td) { border: 1px solid #d9dce6; padding: 0.5rem 0.75rem; text-align: left; }
      footer { border-top: 1px solid #e5e7f0; padding-top: 1.5rem; padding-bottom: 2.5rem; color: var(--muted); font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">Classroom Stack</a>
      <nav aria-label="Main">
        <a href="/">Reviews &amp; Guides</a>
        <a href="/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <section aria-label="Newsletter">
        <p><strong>One useful classroom-AI find, every week.</strong> Hands-on tested, no fluff.</p>
        <!-- Email capture: wire to a free-tier provider before launch (see site/README.md) -->
        <form method="post" action="#" data-todo="newsletter-provider">
          <input type="email" name="email" placeholder="you@school.edu" required aria-label="Email address" />
          <button type="submit">Subscribe</button>
        </form>
      </section>
      <p>Some links on this site are affiliate links — see our <a href="/disclosure">disclosure policy</a>.</p>
      <p>© {new Date().getFullYear()} Classroom Stack. Every tool reviewed here was tested hands-on.</p>
    </footer>
  </body>
</html>
