{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "amarketer-kb-entry.schema.json",
  "title": "Amarketer KB entry frontmatter",
  "type": "object",
  "required": ["id", "type", "name", "description", "summary", "source", "status", "created", "updated"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "type": {"enum": ["program", "offer", "tactic", "channel", "policy", "learned-insight", "reference"]},
    "name": {"type": "string", "maxLength": 80},
    "description": {"type": "string", "maxLength": 200, "description": "One line stating WHEN to use this entry — it does the routing in INDEX.md"},
    "summary": {"type": "string", "maxLength": 500},
    "source": {
      "type": "object",
      "required": ["origin"],
      "additionalProperties": false,
      "properties": {
        "origin": {"type": "string", "description": "URL, document name, 'human', or agent session reference"},
        "retrieved": {"type": "string", "format": "date"}
      }
    },
    "status": {"enum": ["draft", "unverified", "verified", "deprecated"]},
    "created": {"type": "string", "format": "date"},
    "updated": {"type": "string", "format": "date"},
    "valid_until": {"type": ["string", "null"], "format": "date", "description": "MANDATORY for type=offer; hard staleness gate"},
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {"enum": ["high", "medium", "low"]},
        "basis": {"type": "string"}
      }
    },
    "supersedes": {"type": "array", "items": {"type": "string"}},
    "superseded_by": {"type": "string"},
    "contradicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {"id": {"type": "string"}, "note": {"type": "string"}}
      }
    },
    "related": {"type": "array", "items": {"type": "string"}},
    "triggers": {"type": "array", "items": {"type": "string", "pattern": "^IF .+ THEN .+$"}},
    "metrics": {"type": "object"},
    "ai_instructions": {"type": "string"}
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "offer"}}},
      "then": {"required": ["valid_until"]}
    },
    {
      "if": {"properties": {"type": {"const": "learned-insight"}}},
      "then": {"required": ["metrics"]}
    }
  ]
}
